// MCU on PMOD0
IO_LOC "pmod_companion_dout" V19; // IO10 MISO 0
IO_PORT "pmod_companion_dout" PULL_MODE=UP IO_TYPE=LVCMOS33 BANK_VCCIO=3.3;
IO_LOC "pmod_companion_din" V18; // IO11 MOSI 1
IO_PORT "pmod_companion_din" PULL_MODE=UP IO_TYPE=LVCMOS33 BANK_VCCIO=3.3;
IO_LOC "pmod_companion_ss" G22;  // IO12 CSn 2
