IO_PORT "pmod_companion_clk" PULL_MODE=UP IO_TYPE=LVCMOS33 BANK_VCCIO=3.3; 
IO_LOC "pmod_companion_intn" E18; // IO14 IRQn 4
IO_PORT "pmod_companion_intn" PULL_MODE=UP IO_TYPE=LVCMOS33 BANK_VCCIO=3.3;

